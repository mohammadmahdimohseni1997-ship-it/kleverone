# OpenAI-compatible LLM endpoint. The env vars are generic — the client just
# points the OpenAI SDK at whichever base URL / model you set.
#
# OpenRouter free tier (default):
MOONSHOT_API_KEY=sk-or-v1-...
MOONSHOT_BASE_URL=https://openrouter.ai/api/v1
MOONSHOT_MODEL=moonshotai/kimi-k2:free
#
# Moonshot direct (paid):
# MOONSHOT_API_KEY=sk-...
# MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
# MOONSHOT_MODEL=kimi-k2-0905-preview
